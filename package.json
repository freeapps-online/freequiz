{
  "name": "freequizapp",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "pnpm --filter @freequizapp/web dev",
    "build": "pnpm --filter @freequizapp/web build",
    "preview": "pnpm --filter @freequizapp/web preview",
    "cf:deploy": "pnpm build && wrangler pages deploy web/dist",
    "cf:preview": "pnpm build && wrangler pages deploy web/dist --branch preview",
    "test": "pnpm --filter @quiz/web exec tsc -b"
  },
  "devDependencies": {
    "wrangler": "^4.87.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freeappstore-online/quiz.git"
  }
}
